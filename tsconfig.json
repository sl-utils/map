/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "compilerOptions": {
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "lib": [
      "es2020",
      "dom"
    ],
    "paths": {
      "@sl-utils/map": ["types/sl-utils-map.d.ts"]  // 添加这行
    }
  },
  "include": [
    "src/**/*",
    "types/**/*",
  ],
  "exclude": []
}
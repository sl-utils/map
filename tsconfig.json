/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "compilerOptions": {
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": [
      "es2020",
      "dom"
    ],
  },
  "include": [
    "src/**/*",
    "types/**/*",
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}